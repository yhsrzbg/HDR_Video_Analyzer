{
  "name": "hdr-lumex",
  "version": "2.0.0",
  "description": "A desktop HDR video analyzer for brightness, gamut, APL, MaxCLL and MaxFALL.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.hdr-lumex.app",
    "productName": "HDR Lumex",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "assets/**/*",
      "src/**/*",
      "!**/node_modules/ffmpeg-static/ffmpeg*",
      "!**/node_modules/ffprobe-static/bin/**"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "ffmpeg.exe"
        },
        {
          "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
          "to": "ffprobe.exe"
        }
      ]
    },
    "portable": {
      "artifactName": "HDR-Lumex-${os}-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "artifactName": "HDR-Lumex-${os}-${arch}.${ext}",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "node_modules/ffprobe-static/bin/darwin/x64/ffprobe",
          "to": "ffprobe"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo",
      "icon": "assets/icon.png",
      "artifactName": "HDR-Lumex-${os}-${arch}.${ext}",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "node_modules/ffprobe-static/bin/linux/x64/ffprobe",
          "to": "ffprobe"
        }
      ]
    }
  }
}
