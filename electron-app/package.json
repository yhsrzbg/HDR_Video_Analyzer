{
  "name": "hdr-video-analyzer",
  "version": "1.0.0",
  "description": "Electron desktop app for HDR video analysis - analyzes brightness, color gamut, and APL",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.0.0",
    "ffmpeg-static": "^5.2.0",
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.hdr-analyzer.app",
    "productName": "HDR Video Analyzer",
    "files": [
      "**/*",
      "!node_modules/ffmpeg-static/ffmpeg",
      "!node_modules/ffmpeg-static/ffmpeg.exe"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "mac": {
      "target": "dmg",
      "icon": null
    },
    "linux": {
      "target": "AppImage",
      "icon": null
    }
  }
}
